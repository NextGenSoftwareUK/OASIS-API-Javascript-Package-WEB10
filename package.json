{
  "name": "@oasisomniverse/web10-api",
  "version": "1.0.4",
  "publishConfig": { "access": "public" },
  "description": "Isomorphic (Node + browser) JavaScript/TypeScript-friendly client for the WEB10 OASIS Source API - the root of the OASIS stack ('the Omega that is the Alpha'), returning the foundational runtime/version identity plus a live unified status across every layer built on top of it, built on the OASIS WEB10 WebAPI.",
  "main": "index.js",
  "module": "index.mjs",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.mjs",
      "require": "./index.js"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "index.js",
    "index.mjs",
    "index.d.ts",
    "src",
    "docs"
  ],
  "scripts": {
    "generate": "node scripts/generate-modules.js",
    "docs": "node scripts/generate-docs.js",
    "types": "node scripts/generate-types.js",
    "test": "node --test test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/NextGenSoftwareUK/OASIS-API-Javascript-Package-WEB10.git"
  },
  "author": "NextGen Software Ltd",
  "license": "MIT",
  "keywords": [
    "WEB10 Source API",
    "WEB10 WebAPI",
    "OASIS Source",
    "WEB0",
    "Root Layer",
    "Unified Status",
    "OASIS API",
    "WEB 4",
    "WEB 5",
    "WEB 6",
    "WEB 7",
    "WEB 8",
    "WEB 9",
    "WEB 10",
    "Blockchain",
    "Interoperable",
    "Metaverse",
    "Aggregation",
    "HOT-Swappable-Architecture",
    "Decentralised",
    "Distributed",
    "Abstraction-Layer",
    "SSO",
    "Agent-Centric",
    "GOD-Protocol/API",
    "More Coming..."
  ]
}
